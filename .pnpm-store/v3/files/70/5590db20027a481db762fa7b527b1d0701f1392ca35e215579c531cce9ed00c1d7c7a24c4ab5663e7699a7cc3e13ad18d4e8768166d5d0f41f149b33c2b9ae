import { FontProps } from '../font';

export type CircleProps = {
  color: string;
  thickness: number;
  count: number;
};

export type ShellProps = {
  // shell segments count and colors
  enabled: boolean;
  start: number;
  band: number;
  sectors: { color: string, text: string, flip: boolean }[];
  font: FontProps;
};

export type PieLabelFormat = 'percent' | 'key' | 'value' | 'pair' | 'all';

export type PieProps = {
  // ratio of the hallow - 0 => pie
  doughnut: number;
  maxSlices: number;
  slicePad: number;
  cornerRadius: number;

  // color band for all slices
  showValue: boolean;
  maxKeyLength: number;
  valueFont: FontProps;
  labelAlign: boolean;
  sameRing: boolean;
  labelFormat: PieLabelFormat;
  labelGap: number;
  alwaysKey: boolean;

  // only use half circle for pie
  half: boolean;
  needle: boolean;
  polarized: boolean;

  // circle as background
  circle: CircleProps;
  shell: ShellProps;
};