import { FontProps } from './font';

// widget can be added to a graph, it auto sum/avg results.
export type WidgetCompute = 'sum' | 'avg' | 'avg_pct' | 'diff_sum' | 'diff_avg' | 'diff_avg_pct';
export const WidgetComputeNames: Record<WidgetCompute, string> = {
  'sum': 'Sum',
  'avg': 'Average',
  'avg_pct': 'Average %',
  'diff_sum': 'Growth Total',
  'diff_avg': 'Growth Average',
  'diff_avg_pct': 'Growth Average %',
};
export type TagData = {
  value: number;
  compute: WidgetCompute;
  display: string;
  color: string;
  goal: number;
};

export type WidgetType = 'sum' | 'avg' | 'pct';
export type WidgetData = {
  id: string;

  // @deprecated - each tag has its own compute now
  type: WidgetType;
  tags: Record<string, TagData>;
  filters: string[];
  font: FontProps;
  // transpose source data during tags generation
  transpose: boolean;
  // display widget type in text
  displayType: boolean;
};
