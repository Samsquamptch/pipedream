import { TimelineOptions } from 'nebula-js-lib';
import { ChartType, MissingPolicy, SimpleData, TimeUnit } from './common';
import { GeneralProps } from './general';
import { ColumnOptions, GraphSettings, MetricsProps } from './graph';
import { tfmt } from './time';

// a None option
export const NONE = 'None';
export const KEY_WINDOW = '_window_';

const NonPivotCharts = [
  ChartType.BAR_RACE,
  ChartType.BOXPLOT,
  ChartType.SCATTER,
  ChartType.TABLE,
  ChartType.TREE,
  ChartType.WORDCLOUD,
];
export const noPivot = (chart: ChartType) => NonPivotCharts.includes(chart);

// ensure a value is within a precision
export const precise = (value: number, precision: number) => +(+value).toFixed(precision);

// this is nebula time col - reserved.
export const isTimeline = (keys: string[], numMetrics: number): boolean => {
  // support time window in un-aggregated query.
  // such as a simple table query <time, unit, user>
  // on only when there are metrics, it is real timeline query
  return (keys.includes(KEY_WINDOW) && numMetrics > 0);
};

// transform query results into data formats [key, metrics]
// key is x-s, metrics will be list of series value
export const pivot = (
  data: SimpleData,
  pivot: string,
  unit: number,
  type: ChartType,
  policy: MissingPolicy = 'Fill-Null',
): SimpleData => {
  // for some chart type, we want to keep it as is (no keys joint)
  if (noPivot(type)) {
    return { ...data };
  }

  // modes to handle multiple keys
  // 1. all combined as single key
  // 2. 1st key as K, others are combined for different series
  let getKey = (row: any): string => '';
  let getMetrics = (row: any): string[] => [];
  let getValue = (row: any, metric: string) => (+row[metric] || 0);
  const hasPivot = pivot && pivot != NONE;
  const keyName = hasPivot ? pivot : data.keys.join('-');

  // in pivot mode, we always use first key as key
  if (hasPivot) {
    const nonPivotKeys = data.keys.filter(e => e != pivot);
    getKey = (row) => row[keyName];
    getMetrics = (row) => [nonPivotKeys.map(k => {
      // time always needs format after pivoted
      let mv = row[k];
      if (k == KEY_WINDOW) {
        mv = tfmt(+mv, null, unit);
      }
      return mv;
    }).join('-')] || [];
    getValue = (row, metric) => (+row[data.metrics[0]] || 0);
  } else {
    getKey = (row) => data.keys.map(k => row[k]).join('-');
    getMetrics = (row) => data.metrics;
  }

  // transform the data
  const rows: any[] = [];
  const newMetrics = {};
  data.data.map(r => {
    let row = {};
    let existing = null;
    if (keyName) {
      const keyValue = getKey(r);
      existing = rows.find(e => e[keyName] === keyValue);
      row = existing || {};
      row[keyName] = keyValue;
    }

    // get all metrics and its value from current row
    getMetrics(r).map(e => {
      newMetrics[e] = 1;
      row[e] = (row[e] || 0) + getValue(r, e);
    });

    // add this new constructed row into rows
    if (!existing) {
      rows.push(row);
    }
  });

  const frame: SimpleData = {
    data: rows,
    keys: keyName ? [keyName] : [],
    metrics: Object.keys(newMetrics),
    timestamp: data.timestamp,
    continuation: data.continuation,
  };

  // let user choose remove the row or fill 0
  const numMetrics = frame.metrics.length + 1;
  for (let i = rows.length - 1; i >= 0; --i) {
    const row = rows[i];
    const keys = Object.keys(row);
    if (keys.length < numMetrics) {
      if (policy == 'Remove-Row') {
        rows.splice(i, 1);
      } else if (policy == 'Fill-Zero' || policy == 'Fill-Null') {
        frame.metrics.forEach(m => {
          if (!keys.includes(m)) {
            row[m] = (policy == 'Fill-Null') ? null : 0;
          }
        });
      }
    }
  }

  return frame;
};

// pivot back to single metric format with mutliple rows for most chart rendering
// C1, C2, C3
// X,  1 , 2
//  =>
// X, Value
// C2, 1
// C3, 2
const pivotBack = (sd: SimpleData, chart: ChartType, mprops: MetricsProps): SimpleData => {
  const { data, keys, metrics } = sd;
  const shouldPivotBack = data.length == 1 && metrics.length > 1 && !noPivot(chart);
  if (!shouldPivotBack) {
    return sd;
  }

  // now it has only one row with multiple metrics, use metric alias if exists
  const row = data[0];
  const keyCol = keys.map(k => row[k]).join('-') || 'Key';
  const rows = metrics.map(m => {
    const alias = mprops.aliases[m] || m;
    return { [keyCol]: alias, value: row[m] };
  });

  return { ...sd, data: rows, keys: [keyCol], metrics: ['value'] };
};

// ensure a value to a precision
export const rebase = (data: SimpleData, settings: GeneralProps): SimpleData => {
  const baseline = settings?.baseline;
  if (!baseline || baseline === 'Raw') {
    return data;
  }

  // ask to transform the data to base on mean
  const { data: rows, metrics } = data;

  if (baseline === 'Flip') {
    // flip the data in place
    for (let i = rows.length - 1; i >= 0; --i) {
      const row = rows[i];
      metrics.forEach((metric) => {
        const current = (+row[metric] || 0);
        row[metric] = -current;
      });
    }

    return data;
  }

  // compute baseline value for each metric
  const metricMeans: Record<string, number> = {};
  let getBase: (metric: string, i: number) => number = null;
  switch (baseline) {
    case 'First': getBase = (m) => rows[0][m]; break;
    case 'Last': getBase = (m) => rows[rows.length - 1][m]; break;
    case 'Mean':
      metrics.forEach((m) => {
        const [count, sum] = rows.reduce((prev, row) => {
          // count
          prev[0]++;
          prev[1] += +row[m];
          return prev;
        }, [0, 0]);
        metricMeans[m] = count == 0 ? 0 : (sum / count);
      });
      getBase = (m) => metricMeans[m];
      break;
    case 'Prev': getBase = (m, i) => i == 0 ? 0 : rows[i - 1][m]; break;
    default: getBase = (m) => 0;
  }

  // build the rebased graph data from back to front (in place)
  for (let i = rows.length - 1; i >= 0; --i) {
    const row = rows[i];
    metrics.forEach((metric) => {
      const current = (+row[metric] || 0);
      const base = getBase(metric, i);
      row[metric] = current - base;
    });
  }

  return data;
};

// accumulate data based on the settings
export const accumulate = (data: SimpleData, settings: GeneralProps): SimpleData => {
  if (!settings || !settings.accumulated) {
    return data;
  }

  // accumulate data in order in place of data
  const newSd = { ...data };

  // ask to transform the data to base accumulating from the previous row
  const metrics = data.metrics;
  for (let i = 1; i < newSd.data.length; i++) {
    const prev = newSd.data[i - 1];
    const curr = newSd.data[i];
    metrics.forEach(metric => {
      curr[metric] = (+curr[metric] || 0) + (+prev[metric] || 0);
    });
  }

  return newSd;
};

export const percentize = (data: SimpleData, general: GeneralProps): Record<string, ColumnOptions> => {
  if (!general || !general.percentage) {
    return {};
  }

  const { data: rows, metrics } = data;
  const opts: Record<string, ColumnOptions> = {};
  const byKey = general.distribute === 'key';
  if (byKey) {
    rows.forEach((row) => {
      const sum = metrics.reduce((p, m) => p + (+row[m] || 0), 0);
      metrics.forEach((m) => {
        const v = +row[m] || 0;
        row[m] = 100.0 * (sum == 0 ? 1 : v / sum);
        opts[m] = { isPct: true };
      });
    });
  } else {
    metrics.forEach(m => {
      const sum = rows.reduce((p, r) => p + (+r[m] || 0), 0);
      rows.forEach(r => {
        const v = +r[m] || 0;
        r[m] = 100.0 * v / sum;
      });
      opts[m] = { isPct: true };
    });
  }

  return opts;
};

// transform simple data by using, pivot, rebase, and accumulation
export type SimpleTransform = {
  data: SimpleData;
  opts: Record<string, ColumnOptions>;
  pivotKey: string;
};

export const transformSimple = (
  qr: SimpleData,
  pivotKey: string,
  timeline: TimelineOptions,
  chart: ChartType,
  settings: GraphSettings,
): SimpleTransform => {
  const { general, metrics: mprops } = settings;
  const { keys, metrics } = qr;
  const etching = isTimeline(keys, metrics.length) &&
    (!timeline || timeline.unit == TimeUnit.NONE);
  if (etching) {
    if (keys.length > 1) {
      pivotKey = KEY_WINDOW;
    }
  }

  // if the data has single row with multiple metrics, most charts can't render it properly
  // let's convert it to multiple rows with metric name as a new column if user does not prevent it
  if (!pivotKey) {
    qr = pivotBack(qr, chart, mprops);
  }

  // transform data based on query result - map & table do not merge keys
  // const general = graph?.settings.general;
  let data = pivot(qr, pivotKey, timeline?.unit, chart, general?.policy);
  data = rebase(data, general);
  const opts = percentize(data, general);
  data = accumulate(data, general);

  return { data, opts, pivotKey };
};
