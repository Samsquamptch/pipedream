export type PaletteInput = {
  begin: string;
  end: string;
  steps: number;
};

// text anchor type
export type AnchorType = 'start' | 'middle' | 'end' | 'inherit';

// all value could be rebased
export const Baselines = ['Raw', 'Mean', 'First', 'Last', 'Prev', 'Flip'] as const;
export type Baseline = typeof Baselines[number];

// policy to handle missing value when pivoting
export type MissingPolicy = 'Fill-Zero' | 'Fill-Null' | 'Remove-Row';

// options to format value for display
export type ValueOption = 'auto' | 'full' | 'sk' | 'sm' | 'sb' | 'percent';

// define graph margin property
export interface Margin {
  top: number;
  left: number;
  bottom: number;
  right: number;
  f?: boolean;
}

// a simplified linear gradient color
export type GradientColor = {
  degree: number;
  colors: string[];
};

// a short id generator that client can use to generate conformed id
const SUID_14 = new ShortUniqueId({ length: 14 });
export const shortId = (): string => SUID_14.rnd();

// time constants
export const MINUTE_MS = 60_000;
export const FIVE_MINUTE_MS = 5 * MINUTE_MS;
export const TEN_MINUTE_MS = 10 * MINUTE_MS;
export const HOUR_MS = 3600_000;
export const SIX_HOUR_MS = 6 * HOUR_MS;
export const DAY_MS = 24 * HOUR_MS;
export const WEEK_MS = 7 * DAY_MS;
export const MONTH_MS = 30 * DAY_MS;
export enum TimeUnit {
  NONE = 0,
  HOUR = 1,
  DAY = 2,
  WEEK = 3,
  MONTH = 4,
  QUARTER = 5,
  YEAR = 6,
};
const UnitMs: Record<TimeUnit, number> = {
  [TimeUnit.NONE]: 0,
  [TimeUnit.HOUR]: HOUR_MS,
  [TimeUnit.DAY]: DAY_MS,
  [TimeUnit.WEEK]: WEEK_MS,
  [TimeUnit.MONTH]: MONTH_MS,
  [TimeUnit.QUARTER]: 3 * MONTH_MS,
  [TimeUnit.YEAR]: 365 * DAY_MS,
};

export const timeWindowMs = (offset: number, unit: TimeUnit) => offset * UnitMs[unit];
