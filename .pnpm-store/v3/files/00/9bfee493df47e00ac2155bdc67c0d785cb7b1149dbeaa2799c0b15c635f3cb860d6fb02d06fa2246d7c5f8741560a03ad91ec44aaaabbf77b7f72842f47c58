  PIE = 3,
  DOUGHNUT = 4,
  TIMELINE = 5,
  TIMELINE_AREA = 6,
  TIMELINE_BAR = 7,
  BAR_RACE = 8,
  AREA = 9,
  TABLE = 10,
  MAP = 11,
  SCATTER = 12,
  TREE = 13,
  RADAR = 14,
  DOT = 15,
