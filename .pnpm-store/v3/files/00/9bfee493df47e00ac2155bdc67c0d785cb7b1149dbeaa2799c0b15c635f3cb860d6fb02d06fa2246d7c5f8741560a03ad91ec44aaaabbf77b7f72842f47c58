import ShortUniqueId from 'short-unique-id';
import { NebulaRequest } from 'nebula-js-lib';

export const ColumnsVersion = 1;
export const TITLE_ANNOTATION_ID = 'g_auto_title';

export type Currency = {
  currency: string;
  code: string;
  symbol: string;
};

export type Affixes = {
  prefix: string;
  suffix: string;
};

// a simple position with x and y
export interface Position {
  x: number;
  y: number;
  // indicating if the position value is set by human
  f?: boolean;
}

// a simple size with width and height
export interface Size {
  w: number;
  h: number;
}

// a generic range for number values
// value is miliseconds when using it for time 
export type ValueRange = {
  start: number;
  end: number;
};

// a query interface to fetch next data point
export type DataPointQuery = {
  window: number;
  start: number;
  query: NebulaRequest;
};

// A simple data interface: data rows, keys, and metrics
export interface SimpleData {
  data: any[];
  keys: string[];
  metrics: string[];
  timestamp: number;
  continuation?: DataPointQuery;
}

// all supported chart types
